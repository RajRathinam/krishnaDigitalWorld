{
  "expo": {
    "name": "Sk Digital World",
    "slug": "mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/skdw.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/skdw.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.anonymous.mobileapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/skdw.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/sk.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "763bb53c-d4dd-4a8c-8b95-fe4f26bbca60"
      }
    },
    "owner": "rajrathinams"
  }
}
